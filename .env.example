# ============================================
# 邮件系统 - 环境变量配置示例
# 复制为 .env 并填入实际值
# ============================================

# 应用基本配置
APP_NAME=MailSystem
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Shanghai
APP_KEY=PLEASE-CHANGE-ME-TO-A-RANDOM-32-CHAR-STRING

# 数据库配置 (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mail_system
DB_USERNAME=mail_user
DB_PASSWORD=mail_pass_change_me
DB_CHARSET=utf8mb4

# 邮件协议端口
SMTP_PORT=25
SMTP_SSL_PORT=465
SMTP_TLS_PORT=587
POP3_PORT=110
POP3_SSL_PORT=995
IMAP_PORT=143
IMAP_SSL_PORT=993

# 后台管理
ADMIN_PATH=admin
ADMIN_PORT=8080
WEB_PORT=80

# SSL 证书路径 (留空则使用自签名)
SSL_CERT_PATH=
SSL_KEY_PATH=

# 日志
LOG_PATH=./logs
LOG_LEVEL=info

# 存储
MAIL_STORAGE_PATH=./data/mailboxes
UPLOAD_PATH=./data/uploads

# 邮件服务器主机名 (用于 HELO/EHLO 及 Message-ID)
MAIL_HOSTNAME=mail.example.com
