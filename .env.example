# ============================================
# 邮件系统 - 环境变量配置示例
# 复制为 .env 并填入实际值
# ============================================

# 应用基本配置
APP_NAME=MailSystem
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Shanghai
APP_KEY=PLEASE-CHANGE-ME-TO-A-RANDOM-32-CHAR-STRING

# 数据库配置 (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mail_system
DB_USERNAME=mail_user
DB_PASSWORD=mail_pass_change_me
DB_CHARSET=utf8mb4

# 邮件协议端口
SMTP_PORT=25
SMTP_SSL_PORT=465
SMTP_TLS_PORT=587
POP3_PORT=110
POP3_SSL_PORT=995
IMAP_PORT=143
IMAP_SSL_PORT=993

# 邮件发送速率限制 (每秒发送邮件数量)
EMAIL_RATE_LIMIT_PER_SECOND=10

# 后台管理
ADMIN_PATH=admin
ADMIN_PORT=8080
WEB_PORT=80

# SSL 证书路径 (留空则使用自签名)
SSL_CERT_PATH=
SSL_KEY_PATH=

# 日志
LOG_PATH=./logs
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# 存储
MAIL_STORAGE_PATH=./data/mailboxes
UPLOAD_PATH=./data/uploads

# 邮件服务器主机名 (用于 HELO/EHLO 及 Message-ID)
MAIL_HOSTNAME=mail.example.com

# 允许用户注册的邮箱域名 (JSON 数组格式，例如: ["example.com", "mail.example.com"])
ALLOWED_REGISTRATION_DOMAINS=["example.com"]

# DNS 服务商配置 (可选，用于域名管理一键解析)

# DNS 服务商配置 (可选，用于域名管理一键解析)
# 支持: tencentcloud, aliyun, huaweicloud
# DNS_PROVIDER=
# TENCENT_CLOUD_SECRET_ID=
# TENCENT_CLOUD_SECRET_KEY=
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# HUAWEI_CLOUD_AK=
# HUAWEI_CLOUD_SK=
# HUAWEI_CLOUD_PROJECT_ID=

# 安全功能
# REQUIRE_CAPTCHA=true
# REQUIRE_DEVICE_VERIFY=true
# SESSION_TIMEOUT=1800 # 秒，30分钟无操作退出
